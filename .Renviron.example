CLICKHOUSE_HOST=your-clickhouse-host
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=your-database
CLICKHOUSE_USER=your-user
CLICKHOUSE_PASSWORD=your-password
CLICKHOUSE_HTTPS=false

GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret
# OAuth scopes requested when logging in through GitHub.
# Use public_repo for public repositories; use repo if private repositories must be analyzed.
GITHUB_OAUTH_SCOPE=read:user user:email public_repo

CH_HOST=your-clickhouse-host
CH_PORT=8123
CH_DB=your-database
CH_USER=your-user
CH_PASSWORD=your-password

OSV_MONGO_URL=mongodb://localhost:27017
OSV_MONGO_DB=osv
OSV_MONGO_COLLECTION=vulns
MONGODB_URI=mongodb://localhost:27017
MONGO_URI=mongodb://localhost:27017

# OpenAI-compatible AI settings used by Isida/Odin, Maat AI review,
# and Mini-Tot/Mini-raven chat.
OPENAI_BASE_URL=https://routerai.ru/api/v1
OPENAI_MODEL=openai/gpt-oss-120b
OPENAI_API_KEY=your-openai-compatible-api-key

# Number of parallel workers used when collecting commits across repositories.
# Keep at 1 for sequential collection; raise carefully to avoid GitHub rate limits.
# Alias also supported: GITHOUND_COMMIT_COLLECTION_WORKERS.
GITHOUND_COMMIT_WORKERS=1

# Worker budget for the Syft/OSV commit dependency scan in the Set protocol.
# Alias also supported: GITHOUND_OSV_WORKERS.
GITHOUND_COMMIT_SCAN_WORKERS=16

# Vulnerability scan parallel strategy: auto, staged_all, or manual.
# auto is conservative; staged_all can be faster on large profiles but creates more GitHub/API pressure.
GITHOUND_VULN_SCAN_STRATEGY=auto

# Optional caps for vulnerability scan scope. Leave empty for full-quality scans.
GITHOUND_VULN_MAX_REPOS=
GITHOUND_VULN_MAX_COMMITS_PER_REPO=

# Per-Syft scan timeout in seconds. 0 means no timeout.
GITHOUND_SYFT_TIMEOUT_SEC=0

# Parallelize the heavy per-commit Syft + OSV result analysis when repository-level
# parallelism is not already active.
GITHOUND_SYFT_SCAN_PARALLEL=true
GITHOUND_SYFT_SCAN_WORKERS=4

# Comma-separated Syft exclude patterns, for example: **/node_modules/**,**/.git/**
GITHOUND_SYFT_EXCLUDES=

# Enable verbose repository-level vulnerability scan logs.
GITHOUND_VULN_DEBUG=false

# Time zone used for GitHub /rate_limit reset time in the Shiny UI.
# Use an Olson time zone name, for example: Europe/Moscow, Europe/Berlin, America/New_York.
# If empty, the app uses R's system time zone; invalid values fall back to UTC.
GITHOUND_RATE_LIMIT_TZ=Europe/Moscow

# Top-level workers for Set protocol ETL tasks.
# Keep this modest because commit collection can start its own workers.
GITHOUND_SET_WORKERS=2

# Per-commit additions/deletions/changes require one extra GitHub request per commit.
# Leave disabled for much faster Set runs; enable only when those line-change metrics are needed.
GITHOUND_COMMIT_INCLUDE_STATS=false

# Optional cap for candidate repositories during commit collection. Leave empty for no cap.
GITHOUND_COMMIT_MAX_REPOS=

# Code quality protocol (Maat) scope and parallelism.
# It scans repository trees through the GitHub API and stores evidence-based metrics/findings.
GITHOUND_QUALITY_WORKERS=2
GITHOUND_QUALITY_MAX_REPOS=25
GITHOUND_QUALITY_MAX_TREE_FILES=5000
GITHOUND_QUALITY_INCLUDE_PRIVATE=true
GITHOUND_QUALITY_INCLUDE_ARCHIVED=false
GITHOUND_QUALITY_INCLUDE_FORKS=false

# Optional AI layer for Maat. Uses the existing OPENAI_API_KEY / OPENAI_BASE_URL / OPENAI_MODEL settings.
GITHOUND_QUALITY_AI_ENABLED=true
GITHOUND_QUALITY_AI_MODEL=
GITHOUND_QUALITY_AI_WEIGHT=0.2
GITHOUND_QUALITY_AI_CODE_LINES=80
GITHOUND_QUALITY_AI_README_LINES=40
GITHOUND_QUALITY_AI_MAX_READMES=8
GITHOUND_QUALITY_AI_FILES_PER_REPO=4
GITHOUND_QUALITY_AI_FILE_LIST_LIMIT=80
GITHOUND_QUALITY_AI_SELECT_REPO_BATCH=3
GITHOUND_QUALITY_AI_STRUCTURE_LIMIT_PER_REPO=60
GITHOUND_QUALITY_AI_STRUCTURE_TOTAL_LIMIT=600
GITHOUND_QUALITY_AI_MAX_FILE_BYTES=200000
GITHOUND_QUALITY_AI_MAX_CODE_FRAGMENTS=24
GITHOUND_QUALITY_AI_VULN_LIMIT=50
GITHOUND_QUALITY_AI_REVIEW_MAX_INPUT_CHARS=120000
GITHOUND_QUALITY_AI_TIMEOUT_SEC=180
GITHOUND_QUALITY_AI_SELECT_MAX_TOKENS=1200
GITHOUND_QUALITY_AI_REVIEW_MAX_TOKENS=1800
