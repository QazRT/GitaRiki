{
  "api": {
    "base_url_env": "OPENAI_BASE_URL",
    "api_key_env": "OPENAI_API_KEY",
    "default_base_url": "https://routerai.ru/api/v1",
    "chat_endpoint": "/chat/completions",
    "timeout_seconds": 120
  },
  "model": {
    "model_env": "OPENAI_MODEL",
    "default_model": "openai/gpt-oss-120b",
    "temperature": 0,
    "max_tool_rounds": 4,
    "response_language": "ru"
  },
  "clickhouse": {
    "max_rows": 100,
    "allowed_tables": null,
    "readonly": true,
    "tools": [
      "clickhouse_list_tables",
      "clickhouse_describe_table",
      "clickhouse_query"
    ]
  },
  "prompts": {
    "system": "prompts/system.md",
    "role": "prompts/role.md"
  },
  "rag": [
    "rag/clickhouse_context.md",
    "rag/security_rules.md"
  ]
}
